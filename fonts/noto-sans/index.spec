// Font package: Noto Sans
//
// Google's universal sans-serif designed to cover all languages.
// Clean and neutral with excellent CJK support. Used by the
// sakura theme.
//
// Usage:
//   @import "@spec/font-noto-sans"
//
// Then add to your @visual-system:
//   font.body: "'Noto Sans', 'Hiragino Sans', -apple-system, BlinkMacSystemFont, sans-serif"
//   font.heading: "'Noto Sans', 'Hiragino Sans', -apple-system, BlinkMacSystemFont, sans-serif"

@fonts {
  "Noto Sans": 400 "./woff2/noto-sans-regular.woff2", 500 "./woff2/noto-sans-medium.woff2", 600 "./woff2/noto-sans-semibold.woff2", 700 "./woff2/noto-sans-bold.woff2"
}
