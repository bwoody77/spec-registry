@theme ocean {
  palette.primary: teal
  semantic.surface: "#0C1929"
  semantic.surface-raised: "#132237"
  semantic.surface-hover: "#1B3048"
  semantic.background: "#081220"
  semantic.border: "#1E3A5F"
  semantic.border-strong: "#2E5580"
  semantic.text-primary: "#E0F2FE"
  semantic.text-secondary: "#93C5FD"
  semantic.text-tertiary: "#6B9DCF"
  semantic.text-disabled: "#2E5580"
  semantic.text-muted: "#7DBBF0"
  semantic.text-strong: "#F0F9FF"
  semantic.interactive: "#2DD4BF"
  semantic.interactive-hover: "#14B8A6"
  semantic.interactive-active: "#0D9488"
  semantic.focus-ring: "rgba(45,212,191,0.4)"
  semantic.info-bg: "#0C1F3A"
  semantic.surface-unread: "#102844"
  semantic.destructive: "#FB7185"
  semantic.destructive-hover: "#F43F5E"
  semantic.error: "#F43F5E"
  semantic.error-bg: "#2D1520"
  semantic.success: "#34D399"
  semantic.success-light: "#0A2E22"
  semantic.success-muted: "#10402E"
  semantic.success-text: "#34D399"
  semantic.success-mid: "#6EE7B7"
  semantic.warning: "#FBBF24"
  semantic.warning-light: "#2D2510"
  semantic.warning-muted: "#3D3218"
  semantic.warning-text: "#FDE68A"
  semantic.on-interactive: "#081220"
  semantic.on-destructive: "#081220"
  semantic.focus-ring-shadow: "rgba(45,212,191,.2)"
  // Severity
  severity.info-bg: "#0C1F3A"
  severity.info-color: "#2DD4BF"
  severity.info-border: "#1E3A5F"
  severity.success-bg: "#0A2E22"
  severity.success-color: "#34D399"
  severity.success-border: "#10402E"
  severity.warning-bg: "#2D2510"
  severity.warning-color: "#FBBF24"
  severity.warning-border: "#3D3218"
  severity.error-bg: "#2D1520"
  severity.error-color: "#FB7185"
  severity.error-border: "#3D1F2A"

  font.body: "'Inter', 'Segoe UI', sans-serif"
  font.heading: "'Inter', 'Segoe UI', sans-serif"

  radius.sm: "8px"
  radius.md: "10px"
  radius.lg: "14px"

  borders.default: "1px solid #1E3A5F"
  borders.strong: "1px solid #2E5580"

  elevation.flat: "none"
  elevation.raised: "0 2px 6px rgba(0,0,0,0.3), 0 0 0 1px rgba(45,212,191,0.05)"
  elevation.layered: "0 4px 12px rgba(0,0,0,0.3), 0 0 0 1px rgba(45,212,191,0.05)"
  elevation.floating: "0 12px 36px rgba(0,0,0,0.4), 0 0 0 1px rgba(45,212,191,0.08)"
  elevation.overlay: "0 8px 32px rgba(0,0,0,0.5)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  // Component tokens
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#132237"
  btn-secondary-color: "#93C5FD"
  btn-secondary-border: "#1E3A5F"
  btn-secondary-hover: "#1B3048"
  btn-ghost-color: "#93C5FD"
  btn-ghost-hover: "#1B3048"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#132237"
  input-border: "#1E3A5F"
  input-color: "#E0F2FE"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  input-radius: "10px"
  toggle-trackBg: "#1E3A5F"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#081220"
  select-border: "#1E3A5F"
  select-bg: "#132237"
  select-radius: "10px"
  select-optionHover: "#1B3048"
  select-optionSelected: "#0C1F3A"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#132237"
  modal-radius: "14px"
  modal-shadow: "0 20px 60px rgba(0,0,0,.45)"
  checkbox-border: "#1E3A5F"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#1E3A5F"
  tab-hoverBg: "rgba(255,255,255,.05)"
  // Alert — Ocean severity
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "#FDE68A"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Ocean depths
  gradient.stat-primary: "linear-gradient(135deg, #0C1929, #0C1F3A)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #0C1929, #102030)"
  gradient.stat-success: "linear-gradient(135deg, #0A2E22, #10402E)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #0C1929, #0A2E22)"
  gradient.stat-warning: "linear-gradient(135deg, #2D2510, #3D3218)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #0C1929, #2D2510)"
  gradient.stat-neutral: "linear-gradient(135deg, #0C1929, #132237)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #0C1929, #0F1C2E)"
  gradient.header-accent: "linear-gradient(135deg, rgba(45,212,191,0.15), rgba(45,212,191,0.05))"
  // Badge — Ocean
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#132237"
  badge-neutral-color: "#93C5FD"
  badge-neutral-border: "#1E3A5F"
  // Progress
  progress-trackBg: "#1E3A5F"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#1B3048"
  skeleton-shimmer: "rgba(45,212,191,0.06)"
  grid-borderColor: "#1E3A5F"
  grid-headerBg: "#0C1929"
  grid-filterBg: "#0C1929"
  grid-filterBorder: "#1E3A5F"
  grid-rowBorder: "#132237"
  grid-selectedBg: "#0C1F3A"
  scrollbar-color: "#1E3A5F #0C1929"
}
