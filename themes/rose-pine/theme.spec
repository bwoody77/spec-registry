@theme rose-pine {
  palette.primary: rose
  semantic.surface: "#191724"
  semantic.surface-raised: "#1F1D2E"
  semantic.surface-hover: "#26233A"
  semantic.background: "#131120"
  semantic.border: "#3A3650"
  semantic.border-strong: "#524A6E"
  semantic.text-primary: "#E0DEF4"
  semantic.text-secondary: "#C4C0D8"
  semantic.text-tertiary: "#908CAA"
  semantic.text-disabled: "#524A6E"
  semantic.text-muted: "#A8A4C0"
  semantic.text-strong: "#FFFFFF"
  semantic.interactive: "#EBBCBA"
  semantic.interactive-hover: "#D6A5A3"
  semantic.interactive-active: "#C49090"
  semantic.focus-ring: "rgba(235,188,186,0.4)"
  semantic.info-bg: "#1E1C30"
  semantic.surface-unread: "#221F34"
  semantic.destructive: "#EB6F92"
  semantic.destructive-hover: "#D45E80"
  semantic.error: "#EB6F92"
  semantic.error-bg: "#2E1C28"
  semantic.success: "#9CCFD8"
  semantic.success-light: "#1A2830"
  semantic.success-muted: "#203438"
  semantic.success-text: "#9CCFD8"
  semantic.success-mid: "#88B8C0"
  semantic.warning: "#F6C177"
  semantic.warning-light: "#302818"
  semantic.warning-muted: "#3E3420"
  semantic.warning-text: "#F6C177"
  semantic.on-interactive: "#191724"
  semantic.on-destructive: "#191724"
  semantic.focus-ring-shadow: "rgba(235,188,186,.2)"
  // Severity
  severity.info-bg: "#1E1C30"
  severity.info-color: "#C4A7E7"
  severity.info-border: "#3A3650"
  severity.success-bg: "#1A2830"
  severity.success-color: "#9CCFD8"
  severity.success-border: "#203438"
  severity.warning-bg: "#302818"
  severity.warning-color: "#F6C177"
  severity.warning-border: "#3E3420"
  severity.error-bg: "#2E1C28"
  severity.error-color: "#EB6F92"
  severity.error-border: "#442838"

  font.body: "'Inter', 'Segoe UI', sans-serif"
  font.heading: "'Inter', 'Segoe UI', sans-serif"

  radius.sm: "6px"
  radius.md: "8px"
  radius.lg: "12px"

  borders.default: "1px solid #3A3650"
  borders.strong: "1px solid #524A6E"

  elevation.flat: "none"
  elevation.raised: "0 2px 6px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2)"
  elevation.layered: "0 4px 10px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2)"
  elevation.floating: "0 12px 30px rgba(0,0,0,0.4), 0 4px 10px rgba(0,0,0,0.2)"
  elevation.overlay: "0 8px 32px rgba(0,0,0,0.45)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  btn-radius: "8px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#1F1D2E"
  btn-secondary-color: "#E0DEF4"
  btn-secondary-border: "#524A6E"
  btn-secondary-hover: "#26233A"
  btn-ghost-color: "#C4C0D8"
  btn-ghost-hover: "#26233A"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#1F1D2E"
  input-border: "#524A6E"
  input-color: "#E0DEF4"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#3A3650"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#191724"
  select-border: "#524A6E"
  select-bg: "#1F1D2E"
  select-optionHover: "#26233A"
  select-optionSelected: "#221F34"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#1F1D2E"
  modal-radius: "12px"
  modal-shadow: "0 20px 60px rgba(0,0,0,.45)"
  checkbox-border: "#524A6E"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#3A3650"
  tab-hoverBg: "rgba(255,255,255,.05)"
  // Alert — Rosé Pine
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Rosé Pine
  gradient.stat-primary: "linear-gradient(135deg, #191724, #221F34)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #191724, #1E1C30)"
  gradient.stat-success: "linear-gradient(135deg, #1A2830, #203438)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #191724, #1A2830)"
  gradient.stat-warning: "linear-gradient(135deg, #302818, #3E3420)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #191724, #302818)"
  gradient.stat-neutral: "linear-gradient(135deg, #191724, #1F1D2E)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #191724, #1C1A28)"
  gradient.header-accent: "linear-gradient(135deg, rgba(235,188,186,0.15), rgba(196,167,231,0.08))"
  // Badge — Rosé Pine
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#1F1D2E"
  badge-neutral-color: "#C4C0D8"
  badge-neutral-border: "#3A3650"
  // Progress
  progress-trackBg: "#3A3650"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#26233A"
  skeleton-shimmer: "rgba(235,188,186,0.06)"
  grid-borderColor: "#3A3650"
  grid-headerBg: "#191724"
  grid-filterBg: "#191724"
  grid-filterBorder: "#524A6E"
  grid-rowBorder: "#1F1D2E"
  grid-selectedBg: "#221F34"
  scrollbar-color: "#524A6E #191724"
}
