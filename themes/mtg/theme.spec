@theme mtg {
  palette.primary: amber
  semantic.surface: "#1C1712"
  semantic.surface-raised: "#262018"
  semantic.surface-hover: "#302820"
  semantic.background: "#141008"
  semantic.border: "#5C4A30"
  semantic.border-strong: "#7A6440"
  semantic.text-primary: "#E8DCC8"
  semantic.text-secondary: "#C0B090"
  semantic.text-tertiary: "#887860"
  semantic.text-disabled: "#5C4A30"
  semantic.text-muted: "#A89878"
  semantic.text-strong: "#F0E8D8"
  semantic.interactive: "#D4A836"
  semantic.interactive-hover: "#C09428"
  semantic.interactive-active: "#A88020"
  semantic.focus-ring: "rgba(212,168,54,0.4)"
  semantic.info-bg: "#1C1818"
  semantic.surface-unread: "#22201A"
  semantic.destructive: "#C84040"
  semantic.destructive-hover: "#B03030"
  semantic.error: "#C84040"
  semantic.error-bg: "#281818"
  semantic.success: "#5AAC58"
  semantic.success-light: "#142014"
  semantic.success-muted: "#1C2C1C"
  semantic.success-text: "#5AAC58"
  semantic.success-mid: "#4A984A"
  semantic.warning: "#D09030"
  semantic.warning-light: "#282010"
  semantic.warning-muted: "#342818"
  semantic.warning-text: "#D09030"
  semantic.on-interactive: "#141008"
  semantic.on-destructive: "#FFFFFF"
  semantic.focus-ring-shadow: "rgba(212,168,54,.2)"
  // Severity
  severity.info-bg: "#1C1818"
  severity.info-color: "#8090C0"
  severity.info-border: "#5C4A30"
  severity.success-bg: "#142014"
  severity.success-color: "#5AAC58"
  severity.success-border: "#1C2C1C"
  severity.warning-bg: "#282010"
  severity.warning-color: "#D09030"
  severity.warning-border: "#342818"
  severity.error-bg: "#281818"
  severity.error-color: "#C84040"
  severity.error-border: "#402020"

  font.body: "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
  font.heading: "'Palatino Linotype', 'Book Antiqua', Palatino, serif"

  radius.sm: "4px"
  radius.md: "6px"
  radius.lg: "10px"

  borders.default: "1px solid #5C4A30"
  borders.strong: "1px solid #7A6440"

  elevation.flat: "none"
  elevation.raised: "0 2px 6px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2)"
  elevation.layered: "0 4px 10px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2)"
  elevation.floating: "0 12px 30px rgba(0,0,0,0.4), 0 4px 10px rgba(0,0,0,0.2)"
  elevation.overlay: "0 8px 32px rgba(0,0,0,0.45)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  btn-radius: "6px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#262018"
  btn-secondary-color: "#E8DCC8"
  btn-secondary-border: "#7A6440"
  btn-secondary-hover: "#302820"
  btn-ghost-color: "#C0B090"
  btn-ghost-hover: "#302820"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#262018"
  input-border: "#7A6440"
  input-color: "#E8DCC8"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#5C4A30"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#1C1712"
  select-border: "#7A6440"
  select-bg: "#262018"
  select-optionHover: "#302820"
  select-optionSelected: "#22201A"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#262018"
  modal-radius: "10px"
  modal-shadow: "0 20px 60px rgba(0,0,0,.45)"
  checkbox-border: "#7A6440"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#5C4A30"
  tab-hoverBg: "rgba(212,168,54,.06)"
  // Alert — MTG
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — MTG
  gradient.stat-primary: "linear-gradient(135deg, #1C1712, #22201A)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #1C1712, #1E1A14)"
  gradient.stat-success: "linear-gradient(135deg, #142014, #1C2C1C)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #1C1712, #142014)"
  gradient.stat-warning: "linear-gradient(135deg, #282010, #342818)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #1C1712, #282010)"
  gradient.stat-neutral: "linear-gradient(135deg, #1C1712, #262018)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #1C1712, #201C14)"
  gradient.header-accent: "linear-gradient(135deg, rgba(212,168,54,0.15), rgba(212,168,54,0.05))"
  // Badge — MTG
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#262018"
  badge-neutral-color: "#C0B090"
  badge-neutral-border: "#5C4A30"
  // Progress
  progress-trackBg: "#5C4A30"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#302820"
  skeleton-shimmer: "rgba(212,168,54,0.06)"
  grid-borderColor: "#5C4A30"
  grid-headerBg: "#1C1712"
  grid-filterBg: "#1C1712"
  grid-filterBorder: "#7A6440"
  grid-rowBorder: "#262018"
  grid-selectedBg: "#22201A"
  scrollbar-color: "#7A6440 #1C1712"
}
