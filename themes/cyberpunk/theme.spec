@theme cyberpunk {
  palette.primary: pink
  semantic.surface: "#0D001A"
  semantic.surface-raised: "#1A0033"
  semantic.surface-hover: "#2D0052"
  semantic.background: "#08000F"
  semantic.border: "#FF2D95"
  semantic.border-strong: "#FF2D95"
  semantic.text-primary: "#F0E6FF"
  semantic.text-secondary: "#C084FC"
  semantic.text-tertiary: "#8B5CF6"
  semantic.text-disabled: "#4C1D95"
  semantic.text-muted: "#A78BFA"
  semantic.text-strong: "#FFFFFF"
  semantic.interactive: "#FF2D95"
  semantic.interactive-hover: "#FF69B4"
  semantic.interactive-active: "#DB2777"
  semantic.focus-ring: "rgba(255,45,149,0.5)"
  semantic.info-bg: "#1A0033"
  semantic.surface-unread: "#220044"
  semantic.destructive: "#FF2D2D"
  semantic.destructive-hover: "#E01B1B"
  semantic.error: "#FF2D2D"
  semantic.error-bg: "#2D0010"
  semantic.success: "#00FF88"
  semantic.success-light: "#001A0D"
  semantic.success-muted: "#003320"
  semantic.success-text: "#00FF88"
  semantic.success-mid: "#00CC6A"
  semantic.warning: "#FFE600"
  semantic.warning-light: "#1A1A00"
  semantic.warning-muted: "#333300"
  semantic.warning-text: "#FFE600"
  semantic.on-interactive: "#08000F"
  semantic.on-destructive: "#08000F"
  semantic.focus-ring-shadow: "rgba(0,240,255,.25)"
  // Severity
  severity.info-bg: "#1A0033"
  severity.info-color: "#00F0FF"
  severity.info-border: "#00F0FF"
  severity.success-bg: "#001A0D"
  severity.success-color: "#00FF88"
  severity.success-border: "#00FF88"
  severity.warning-bg: "#1A1A00"
  severity.warning-color: "#FFE600"
  severity.warning-border: "#FFE600"
  severity.error-bg: "#2D0010"
  severity.error-color: "#FF2D2D"
  severity.error-border: "#FF2D2D"

  font.body: "'Rajdhani', 'Orbitron', 'Consolas', monospace"
  font.heading: "'Rajdhani', 'Orbitron', 'Consolas', monospace"

  radius.sm: "2px"
  radius.md: "4px"
  radius.lg: "6px"

  borders.default: "1px solid #FF2D95"
  borders.strong: "1px solid #FF69B4"

  elevation.flat: "none"
  elevation.raised: "0 0 12px rgba(255,45,149,0.3), 0 0 4px rgba(0,240,255,0.15)"
  elevation.layered: "0 0 24px rgba(255,45,149,0.25), 0 0 8px rgba(0,240,255,0.12)"
  elevation.floating: "0 0 48px rgba(255,45,149,0.3), 0 0 16px rgba(0,240,255,0.2)"
  elevation.overlay: "0 0 60px rgba(255,45,149,0.35)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.4)"

  // Component tokens
  btn-radius: "2px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#1A0033"
  btn-secondary-color: "#FF2D95"
  btn-secondary-border: "#FF2D95"
  btn-secondary-hover: "#2D0052"
  btn-ghost-color: "#C084FC"
  btn-ghost-hover: "#2D0052"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  btn-fontWeight: "600"
  btn-textTransform: "uppercase"
  btn-letterSpacing: "0.08em"
  btn-shadow: "0 0 10px rgba(255,45,149,0.4), inset 0 0 4px rgba(255,45,149,0.15)"
  input-bg: "#1A0033"
  input-border: "#FF2D95"
  input-color: "#F0E6FF"
  input-radius: "2px"
  input-focusBorder: "#00F0FF"
  input-focusRing: "semantic.focus-ring-shadow"
  input-shadow: "0 0 8px rgba(255,45,149,0.2)"
  select-bg: "#1A0033"
  select-border: "#FF2D95"
  select-radius: "2px"
  select-optionHover: "#2D0052"
  select-optionSelected: "#3D006B"
  toggle-trackBg: "#2D0052"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#08000F"
  toggle-radius: "2px"
  modal-backdropBg: "rgba(8,0,15,.85)"
  modal-bg: "#1A0033"
  modal-radius: "4px"
  modal-shadow: "0 0 40px rgba(255,45,149,0.4), 0 0 0 1px #FF2D95"
  checkbox-border: "#FF2D95"
  checkbox-checkedBg: "semantic.interactive"
  checkbox-radius: "2px"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#FF2D95"
  tab-hoverBg: "#2D0052"
  // Alert — cyberpunk neon severity
  alert-radius: "2px"
  alert-shadow: "0 0 10px rgba(255,45,149,0.2)"
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — cyberpunk neon on dark
  gradient.stat-primary: "linear-gradient(135deg, #1A0033, #3D006B)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #0D001A, #1A0033)"
  gradient.stat-success: "linear-gradient(135deg, #001A0D, #003320)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #0D001A, #001A0D)"
  gradient.stat-warning: "linear-gradient(135deg, #1A1A00, #333300)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #0D001A, #1A1A00)"
  gradient.stat-neutral: "linear-gradient(135deg, #0D001A, #1A0033)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #0D001A, #140026)"
  gradient.header-accent: "linear-gradient(135deg, rgba(255,45,149,0.15), rgba(0,240,255,0.08))"
  // Badge — Cyberpunk
  badge-borderWidth: "1px"
  badge-fontSize: "11px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#1A0033"
  badge-neutral-color: "#C084FC"
  badge-neutral-border: "#8B5CF6"
  // Progress
  progress-trackBg: "#2D0052"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#2D0052"
  skeleton-shimmer: "rgba(255,45,149,0.08)"
  grid-borderColor: "#FF2D95"
  grid-headerBg: "#0D001A"
  grid-filterBg: "#0D001A"
  grid-filterBorder: "#FF2D95"
  grid-rowBorder: "#1A0033"
  grid-selectedBg: "#3D006B"
  scrollbar-color: "#FF2D95 #0D001A"
}
