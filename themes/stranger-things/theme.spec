@theme stranger-things {
  palette.primary: red
  semantic.surface: "#0C0808"
  semantic.surface-raised: "#181010"
  semantic.surface-hover: "#241818"
  semantic.background: "#080505"
  semantic.border: "#3A1C1C"
  semantic.border-strong: "#5A2828"
  semantic.text-primary: "#F0D8D0"
  semantic.text-secondary: "#C8A8A0"
  semantic.text-tertiary: "#886060"
  semantic.text-disabled: "#503838"
  semantic.text-muted: "#A08078"
  semantic.text-strong: "#FFFFFF"
  semantic.interactive: "#E82020"
  semantic.interactive-hover: "#CC1818"
  semantic.interactive-active: "#B01010"
  semantic.focus-ring: "rgba(232,32,32,0.4)"
  semantic.info-bg: "#181018"
  semantic.surface-unread: "#1C1014"
  semantic.destructive: "#FF3030"
  semantic.destructive-hover: "#E02020"
  semantic.error: "#FF3030"
  semantic.error-bg: "#301010"
  semantic.success: "#48C070"
  semantic.success-light: "#0C2018"
  semantic.success-muted: "#142C1C"
  semantic.success-text: "#48C070"
  semantic.success-mid: "#38A860"
  semantic.warning: "#E8A030"
  semantic.warning-light: "#281C08"
  semantic.warning-muted: "#342410"
  semantic.warning-text: "#E8A030"
  semantic.on-interactive: "#FFFFFF"
  semantic.on-destructive: "#FFFFFF"
  semantic.focus-ring-shadow: "rgba(232,32,32,.2)"
  // Severity
  severity.info-bg: "#181018"
  severity.info-color: "#A080C0"
  severity.info-border: "#3A1C1C"
  severity.success-bg: "#0C2018"
  severity.success-color: "#48C070"
  severity.success-border: "#142C1C"
  severity.warning-bg: "#281C08"
  severity.warning-color: "#E8A030"
  severity.warning-border: "#342410"
  severity.error-bg: "#301010"
  severity.error-color: "#FF3030"
  severity.error-border: "#502020"

  font.body: "'Courier New', 'Courier', monospace"
  font.heading: "'Courier New', 'Courier', monospace"

  radius.sm: "4px"
  radius.md: "6px"
  radius.lg: "8px"

  borders.default: "1px solid #3A1C1C"
  borders.strong: "1px solid #5A2828"

  elevation.flat: "none"
  elevation.raised: "0 2px 12px rgba(232,32,32,0.2), 0 1px 4px rgba(0,0,0,0.3)"
  elevation.layered: "0 4px 20px rgba(232,32,32,0.25), 0 2px 8px rgba(0,0,0,0.3)"
  elevation.floating: "0 8px 36px rgba(232,32,32,0.3), 0 4px 14px rgba(0,0,0,0.35)"
  elevation.overlay: "0 12px 48px rgba(232,32,32,0.25), 0 0 0 1px rgba(232,32,32,0.15)"
  elevation.inset: "inset 0 2px 6px rgba(232,32,32,0.15), inset 0 1px 3px rgba(0,0,0,0.3)"

  btn-radius: "6px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#181010"
  btn-secondary-color: "#F0D8D0"
  btn-secondary-border: "#5A2828"
  btn-secondary-hover: "#241818"
  btn-ghost-color: "#C8A8A0"
  btn-ghost-hover: "#241818"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#181010"
  input-border: "#5A2828"
  input-color: "#F0D8D0"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#3A1C1C"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#0C0808"
  select-border: "#5A2828"
  select-bg: "#181010"
  select-optionHover: "#241818"
  select-optionSelected: "#1C1014"
  modal-backdropBg: "rgba(0,0,0,.7)"
  modal-bg: "#181010"
  modal-radius: "8px"
  modal-shadow: "0 20px 60px rgba(232,32,32,.25), 0 0 40px rgba(232,32,32,0.1), 0 0 0 1px rgba(232,32,32,0.15)"
  checkbox-border: "#5A2828"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#3A1C1C"
  tab-hoverBg: "rgba(232,32,32,.06)"
  // Alert — Stranger Things
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Stranger Things
  gradient.stat-primary: "linear-gradient(135deg, #0C0808, #1C1014)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #0C0808, #141010)"
  gradient.stat-success: "linear-gradient(135deg, #0C2018, #142C1C)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #0C0808, #0C2018)"
  gradient.stat-warning: "linear-gradient(135deg, #281C08, #342410)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #0C0808, #281C08)"
  gradient.stat-neutral: "linear-gradient(135deg, #0C0808, #181010)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #0C0808, #120C0C)"
  gradient.header-accent: "linear-gradient(135deg, rgba(232,32,32,0.15), rgba(232,32,32,0.05))"
  // Badge — Stranger Things
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#181010"
  badge-neutral-color: "#C8A8A0"
  badge-neutral-border: "#3A1C1C"
  // Progress
  progress-trackBg: "#3A1C1C"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#241818"
  skeleton-shimmer: "rgba(232,32,32,0.06)"
  grid-borderColor: "#3A1C1C"
  grid-headerBg: "#0C0808"
  grid-filterBg: "#0C0808"
  grid-filterBorder: "#5A2828"
  grid-rowBorder: "#181010"
  grid-selectedBg: "#1C1014"
  scrollbar-color: "#5A2828 #0C0808"
}
