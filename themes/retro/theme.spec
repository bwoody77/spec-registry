@theme retro {
  palette.primary: amber
  semantic.surface: "#0A0800"
  semantic.surface-raised: "#141200"
  semantic.surface-hover: "#1E1A00"
  semantic.background: "#050400"
  semantic.border: "#FFB000"
  semantic.border-strong: "#FFB000"
  semantic.text-primary: "#FFB000"
  semantic.text-secondary: "#CC8C00"
  semantic.text-tertiary: "#997000"
  semantic.text-disabled: "#4D3800"
  semantic.text-muted: "#B89C00"
  semantic.text-strong: "#FFD000"
  semantic.interactive: "#FFB000"
  semantic.interactive-hover: "#FFD040"
  semantic.interactive-active: "#CC8C00"
  semantic.focus-ring: "rgba(255,176,0,0.4)"
  semantic.info-bg: "#141200"
  semantic.surface-unread: "#1A1600"
  semantic.destructive: "#FF3300"
  semantic.destructive-hover: "#CC2900"
  semantic.error: "#FF3300"
  semantic.error-bg: "#1A0800"
  semantic.success: "#FFB000"
  semantic.success-light: "#141200"
  semantic.success-muted: "#1E1A00"
  semantic.success-text: "#FFB000"
  semantic.success-mid: "#CC8C00"
  semantic.warning: "#FFDD00"
  semantic.warning-light: "#1A1800"
  semantic.warning-muted: "#332E00"
  semantic.warning-text: "#FFDD00"
  semantic.on-interactive: "#050400"
  semantic.on-destructive: "#050400"
  semantic.focus-ring-shadow: "rgba(255,176,0,.2)"
  // Severity
  severity.info-bg: "#141200"
  severity.info-color: "#FFB000"
  severity.info-border: "#FFB000"
  severity.success-bg: "#141200"
  severity.success-color: "#FFB000"
  severity.success-border: "#FFB000"
  severity.warning-bg: "#1A1800"
  severity.warning-color: "#FFDD00"
  severity.warning-border: "#FFDD00"
  severity.error-bg: "#1A0800"
  severity.error-color: "#FF3300"
  severity.error-border: "#FF3300"

  font.body: "'Fira Code', 'Courier New', 'Consolas', monospace"
  font.heading: "'Fira Code', 'Courier New', 'Consolas', monospace"

  radius.sm: "2px"
  radius.md: "4px"
  radius.lg: "6px"

  borders.default: "1px solid #FFB000"
  borders.strong: "1px solid #FFD040"

  elevation.flat: "none"
  elevation.raised: "0 0 10px rgba(255,176,0,0.25), 0 0 0 1px rgba(255,176,0,0.3)"
  elevation.layered: "0 0 20px rgba(255,176,0,0.2), 0 0 0 1px rgba(255,176,0,0.3)"
  elevation.floating: "0 0 40px rgba(255,176,0,0.25), 0 0 0 1px rgba(255,176,0,0.3)"
  elevation.overlay: "0 0 50px rgba(255,176,0,0.3)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.4)"

  // Component tokens
  btn-radius: "2px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#0A0800"
  btn-secondary-color: "#FFB000"
  btn-secondary-border: "#FFB000"
  btn-secondary-hover: "#141200"
  btn-ghost-color: "#FFB000"
  btn-ghost-hover: "#141200"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  btn-fontWeight: "400"
  btn-textTransform: "uppercase"
  btn-letterSpacing: "0.1em"
  btn-shadow: "0 0 8px rgba(255,176,0,0.3), inset 0 0 4px rgba(255,176,0,0.1)"
  input-bg: "#0A0800"
  input-border: "#FFB000"
  input-color: "#FFB000"
  input-radius: "2px"
  input-focusBorder: "semantic.interactive-hover"
  input-focusRing: "semantic.focus-ring-shadow"
  input-shadow: "0 0 8px rgba(255,176,0,0.2)"
  select-bg: "#0A0800"
  select-border: "#FFB000"
  select-radius: "2px"
  select-optionHover: "#141200"
  select-optionSelected: "#1E1A00"
  toggle-trackBg: "#1E1A00"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#050400"
  toggle-radius: "2px"
  modal-backdropBg: "rgba(0,0,0,.8)"
  modal-bg: "#0A0800"
  modal-radius: "4px"
  modal-shadow: "0 0 30px rgba(255,176,0,0.3), 0 0 0 1px #FFB000"
  checkbox-border: "#FFB000"
  checkbox-checkedBg: "semantic.interactive"
  checkbox-radius: "2px"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#FFB000"
  tab-hoverBg: "#141200"
  // Alert — Retro amber severity
  alert-radius: "2px"
  alert-shadow: "0 0 8px rgba(255,176,0,0.2)"
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Retro amber on dark
  gradient.stat-primary: "linear-gradient(135deg, #141200, #1E1A00)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #0A0800, #141200)"
  gradient.stat-success: "linear-gradient(135deg, #141200, #1E1A00)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #0A0800, #141200)"
  gradient.stat-warning: "linear-gradient(135deg, #1A1800, #332E00)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #0A0800, #1A1800)"
  gradient.stat-neutral: "linear-gradient(135deg, #0A0800, #141200)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #0A0800, #100E00)"
  gradient.header-accent: "linear-gradient(135deg, rgba(255,176,0,0.15), rgba(255,176,0,0.05))"
  // Badge — Retro
  badge-borderWidth: "1px"
  badge-fontSize: "11px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#141200"
  badge-neutral-color: "#CC8C00"
  badge-neutral-border: "#FFB000"
  // Progress
  progress-trackBg: "#1E1A00"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#1E1A00"
  skeleton-shimmer: "rgba(255,176,0,0.08)"
  grid-borderColor: "#FFB000"
  grid-headerBg: "#0A0800"
  grid-filterBg: "#0A0800"
  grid-filterBorder: "#FFB000"
  grid-rowBorder: "#141200"
  grid-selectedBg: "#1E1A00"
  scrollbar-color: "#FFB000 #0A0800"
}
