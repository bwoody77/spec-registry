@theme gruvbox {
  palette.primary: orange
  semantic.surface: "#282828"
  semantic.surface-raised: "#3C3836"
  semantic.surface-hover: "#504945"
  semantic.background: "#1D2021"
  semantic.border: "#504945"
  semantic.border-strong: "#665C54"
  semantic.text-primary: "#EBDBB2"
  semantic.text-secondary: "#D5C4A1"
  semantic.text-tertiary: "#A89984"
  semantic.text-disabled: "#665C54"
  semantic.text-muted: "#BDAE93"
  semantic.text-strong: "#FBF1C7"
  semantic.interactive: "#FE8019"
  semantic.interactive-hover: "#D65D0E"
  semantic.interactive-active: "#AF3A03"
  semantic.focus-ring: "rgba(254,128,25,0.4)"
  semantic.info-bg: "#32302F"
  semantic.surface-unread: "#3C3530"
  semantic.destructive: "#FB4934"
  semantic.destructive-hover: "#CC241D"
  semantic.error: "#FB4934"
  semantic.error-bg: "#3C2020"
  semantic.success: "#B8BB26"
  semantic.success-light: "#2A2E1E"
  semantic.success-muted: "#343820"
  semantic.success-text: "#B8BB26"
  semantic.success-mid: "#98971A"
  semantic.warning: "#FABD2F"
  semantic.warning-light: "#3C3520"
  semantic.warning-muted: "#4A4228"
  semantic.warning-text: "#FABD2F"
  semantic.on-interactive: "#1D2021"
  semantic.on-destructive: "#1D2021"
  semantic.focus-ring-shadow: "rgba(254,128,25,.2)"
  // Severity
  severity.info-bg: "#32302F"
  severity.info-color: "#83A598"
  severity.info-border: "#504945"
  severity.success-bg: "#2A2E1E"
  severity.success-color: "#B8BB26"
  severity.success-border: "#343820"
  severity.warning-bg: "#3C3520"
  severity.warning-color: "#FABD2F"
  severity.warning-border: "#4A4228"
  severity.error-bg: "#3C2020"
  severity.error-color: "#FB4934"
  severity.error-border: "#502828"

  font.body: "'JetBrains Mono', 'Fira Code', monospace"
  font.heading: "'JetBrains Mono', 'Fira Code', monospace"

  radius.sm: "4px"
  radius.md: "6px"
  radius.lg: "8px"

  borders.default: "1px solid #504945"
  borders.strong: "1px solid #665C54"

  elevation.flat: "none"
  elevation.raised: "0 2px 6px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2)"
  elevation.layered: "0 4px 10px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2)"
  elevation.floating: "0 12px 30px rgba(0,0,0,0.4), 0 4px 10px rgba(0,0,0,0.2)"
  elevation.overlay: "0 8px 32px rgba(0,0,0,0.45)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#3C3836"
  btn-secondary-color: "#EBDBB2"
  btn-secondary-border: "#665C54"
  btn-secondary-hover: "#504945"
  btn-ghost-color: "#D5C4A1"
  btn-ghost-hover: "#504945"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#3C3836"
  input-border: "#665C54"
  input-color: "#EBDBB2"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#504945"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#1D2021"
  select-border: "#665C54"
  select-bg: "#3C3836"
  select-optionHover: "#504945"
  select-optionSelected: "#3C3530"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#3C3836"
  modal-shadow: "0 20px 60px rgba(0,0,0,.45)"
  checkbox-border: "#665C54"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#504945"
  tab-hoverBg: "rgba(255,255,255,.05)"
  // Alert — Gruvbox
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Gruvbox warm tones
  gradient.stat-primary: "linear-gradient(135deg, #282828, #3C3530)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #282828, #32302F)"
  gradient.stat-success: "linear-gradient(135deg, #2A2E1E, #343820)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #282828, #2A2E1E)"
  gradient.stat-warning: "linear-gradient(135deg, #3C3520, #4A4228)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #282828, #3C3520)"
  gradient.stat-neutral: "linear-gradient(135deg, #282828, #3C3836)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #282828, #32302F)"
  gradient.header-accent: "linear-gradient(135deg, rgba(254,128,25,0.15), rgba(254,128,25,0.05))"
  // Badge — Gruvbox
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#3C3836"
  badge-neutral-color: "#D5C4A1"
  badge-neutral-border: "#504945"
  // Progress
  progress-trackBg: "#504945"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#504945"
  skeleton-shimmer: "rgba(255,255,255,0.06)"
  grid-borderColor: "#504945"
  grid-headerBg: "#282828"
  grid-filterBg: "#282828"
  grid-filterBorder: "#665C54"
  grid-rowBorder: "#3C3836"
  grid-selectedBg: "#3C3530"
  scrollbar-color: "#665C54 #282828"
}
