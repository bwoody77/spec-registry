@theme glass {
  palette.primary: violet
  semantic.surface: "rgba(255,255,255,0.15)"
  semantic.surface-raised: "rgba(255,255,255,0.2)"
  semantic.surface-hover: "rgba(255,255,255,0.25)"
  semantic.background: "rgba(255,255,255,0.1)"
  semantic.border: "rgba(255,255,255,0.25)"
  semantic.border-strong: "rgba(255,255,255,0.4)"
  semantic.text-primary: "#ffffff"
  semantic.text-secondary: "rgba(255,255,255,0.8)"
  semantic.text-tertiary: "rgba(255,255,255,0.6)"
  semantic.text-muted: "rgba(255,255,255,0.7)"
  semantic.text-disabled: "rgba(255,255,255,0.3)"
  semantic.interactive: "#a78bfa"
  semantic.interactive-hover: "#8b5cf6"
  semantic.interactive-active: "#7c3aed"
  semantic.focus-ring: "rgba(167,139,250,0.5)"
  semantic.info-bg: "rgba(167,139,250,0.2)"
  semantic.error-bg: "rgba(251,113,133,0.2)"
  semantic.error: "#fb7185"
  semantic.destructive: "#fb7185"
  semantic.destructive-hover: "#f43f5e"
  semantic.success: "#34d399"
  semantic.success-light: "rgba(52,211,153,0.2)"
  semantic.success-muted: "rgba(52,211,153,0.3)"
  semantic.success-text: "#ffffff"
  semantic.success-mid: "#6ee7b7"
  semantic.warning: "#fbbf24"
  semantic.warning-light: "rgba(251,191,36,0.2)"
  semantic.warning-muted: "rgba(251,191,36,0.3)"
  semantic.warning-text: "#ffffff"
  semantic.text-strong: "rgba(255,255,255,0.9)"
  semantic.on-interactive: "#ffffff"
  semantic.on-destructive: "#ffffff"
  semantic.focus-ring-shadow: "rgba(167,139,250,.2)"
  // Severity
  severity.info-bg: "rgba(167,139,250,0.15)"
  severity.info-color: "#ffffff"
  severity.info-border: "rgba(167,139,250,0.4)"
  severity.success-bg: "rgba(52,211,153,0.15)"
  severity.success-color: "#ffffff"
  severity.success-border: "rgba(52,211,153,0.4)"
  severity.warning-bg: "rgba(251,191,36,0.15)"
  severity.warning-color: "#ffffff"
  severity.warning-border: "rgba(251,191,36,0.4)"
  severity.error-bg: "rgba(251,113,133,0.15)"
  severity.error-color: "#ffffff"
  severity.error-border: "rgba(251,113,133,0.4)"

  borders.default: "1px solid rgba(255,255,255,0.2)"
  borders.strong: "1px solid rgba(255,255,255,0.35)"

  surface.backgroundImage: "none"
  surface.backdropFilter: "none"
  //gradient.app-background: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
  gradient.app-background: "linear-gradient(135deg, #2b2b2f 0%, #3536ce 100%)"
  surface.panelBackdropFilter: "blur(12px)"

  radius.sm: "12px"
  radius.md: "16px"
  radius.lg: "20px"

  elevation.raised: "0 4px 16px rgba(0,0,0,0.15), 0 0 0 1px rgba(255,255,255,0.1)"
  elevation.layered: "0 8px 32px rgba(0,0,0,0.2)"
  elevation.floating: "0 16px 48px rgba(0,0,0,0.25)"

  btn-radius: "12px"
  btn-primary-bg: "rgba(167,139,250,0.8)"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "rgba(139,92,246,0.9)"
  btn-secondary-bg: "rgba(255,255,255,0.15)"
  btn-secondary-color: "#ffffff"
  btn-secondary-border: "rgba(255,255,255,0.25)"
  btn-secondary-hover: "rgba(255,255,255,0.25)"
  btn-ghost-color: "rgba(255,255,255,0.8)"
  btn-ghost-hover: "rgba(255,255,255,0.15)"
  btn-destructive-bg: "rgba(251,113,133,0.8)"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "rgba(244,63,94,0.9)"
  input-bg: "rgba(255,255,255,0.1)"
  input-border: "rgba(255,255,255,0.25)"
  input-color: "#ffffff"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  input-radius: "12px"
  select-bg: "rgba(255,255,255,0.15)"
  select-border: "rgba(255,255,255,0.25)"
  select-radius: "12px"
  select-optionHover: "rgba(255,255,255,0.2)"
  select-optionSelected: "rgba(167,139,250,0.3)"
  toggle-trackBg: "rgba(255,255,255,0.2)"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#ffffff"
  modal-backdropBg: "rgba(0,0,0,.4)"
  modal-backdropFilter: "blur(8px)"
  modal-bg: "rgba(255,255,255,0.15)"
  modal-radius: "20px"
  modal-shadow: "0 20px 60px rgba(0,0,0,.3), 0 0 0 1px rgba(255,255,255,0.1)"
  checkbox-border: "rgba(255,255,255,0.3)"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "rgba(255,255,255,0.2)"
  tab-hoverBg: "rgba(255,255,255,0.1)"
  badge-radius: "12px"
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "rgba(255,255,255,0.1)"
  badge-neutral-color: "rgba(255,255,255,0.8)"
  badge-neutral-border: "rgba(255,255,255,0.25)"
  // Stat card gradients — glass: translucent with higher opacity for visibility
  gradient.stat-primary: "linear-gradient(135deg, rgba(167,139,250,0.4), rgba(167,139,250,0.2))"
  gradient.stat-primary-subtle: "linear-gradient(135deg, rgba(167,139,250,0.3), rgba(167,139,250,0.15))"
  gradient.stat-success: "linear-gradient(135deg, rgba(52,211,153,0.4), rgba(52,211,153,0.2))"
  gradient.stat-success-subtle: "linear-gradient(135deg, rgba(52,211,153,0.3), rgba(52,211,153,0.15))"
  gradient.stat-warning: "linear-gradient(135deg, rgba(251,191,36,0.4), rgba(251,191,36,0.2))"
  gradient.stat-warning-subtle: "linear-gradient(135deg, rgba(251,191,36,0.3), rgba(251,191,36,0.15))"
  gradient.stat-neutral: "linear-gradient(135deg, rgba(255,255,255,0.25), rgba(255,255,255,0.12))"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08))"
  gradient.header-accent: "linear-gradient(135deg, rgba(167,139,250,0.15), rgba(167,139,250,0.05))"
  // Alert — glass: translucent severity colors
  alert-radius: "16px"
  alert-info-bg: "severity.info-bg"
  alert-info-border: "rgba(167,139,250,0.4)"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "rgba(52,211,153,0.4)"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "rgba(251,191,36,0.4)"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "rgba(251,113,133,0.4)"
  alert-error-text: "severity.error-color"
  // Progress
  progress-trackBg: "rgba(255,255,255,0.15)"
  progress-fillBg: "semantic.interactive"
  // Scrollbar
  // Skeleton + Grid (glass surfaces)
  skeleton-bg: "rgba(255,255,255,0.15)"
  skeleton-shimmer: "rgba(255,255,255,0.2)"
  grid-borderColor: "rgba(255,255,255,0.2)"
  grid-headerBg: "rgba(255,255,255,0.1)"
  grid-filterBg: "rgba(255,255,255,0.1)"
  grid-filterBorder: "rgba(255,255,255,0.25)"
  grid-rowBorder: "rgba(255,255,255,0.1)"
  grid-selectedBg: "rgba(167,139,250,0.2)"
  scrollbar-color: "rgba(255,255,255,0.3) transparent"
}
