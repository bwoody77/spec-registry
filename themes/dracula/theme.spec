@theme dracula {
  palette.primary: purple
  semantic.surface: "#282A36"
  semantic.surface-raised: "#343746"
  semantic.surface-hover: "#44475A"
  semantic.background: "#21222C"
  semantic.border: "#44475A"
  semantic.border-strong: "#6272A4"
  semantic.text-primary: "#F8F8F2"
  semantic.text-secondary: "#BFBFBF"
  semantic.text-tertiary: "#6272A4"
  semantic.text-disabled: "#44475A"
  semantic.text-muted: "#9EA4B8"
  semantic.text-strong: "#FFFFFF"
  semantic.interactive: "#BD93F9"
  semantic.interactive-hover: "#A580E0"
  semantic.interactive-active: "#9370DB"
  semantic.focus-ring: "rgba(189,147,249,0.4)"
  semantic.info-bg: "#2D2B3D"
  semantic.surface-unread: "#2E2D42"
  semantic.destructive: "#FF5555"
  semantic.destructive-hover: "#E04848"
  semantic.error: "#FF5555"
  semantic.error-bg: "#3D2828"
  semantic.success: "#50FA7B"
  semantic.success-light: "#1A3328"
  semantic.success-muted: "#234430"
  semantic.success-text: "#50FA7B"
  semantic.success-mid: "#45E06B"
  semantic.warning: "#FFB86C"
  semantic.warning-light: "#3D3020"
  semantic.warning-muted: "#4A3A28"
  semantic.warning-text: "#FFB86C"
  semantic.on-interactive: "#21222C"
  semantic.on-destructive: "#21222C"
  semantic.focus-ring-shadow: "rgba(189,147,249,.2)"
  // Severity
  severity.info-bg: "#2D2B3D"
  severity.info-color: "#8BE9FD"
  severity.info-border: "#6272A4"
  severity.success-bg: "#1A3328"
  severity.success-color: "#50FA7B"
  severity.success-border: "#234430"
  severity.warning-bg: "#3D3020"
  severity.warning-color: "#FFB86C"
  severity.warning-border: "#4A3A28"
  severity.error-bg: "#3D2828"
  severity.error-color: "#FF5555"
  severity.error-border: "#5A3030"

  font.body: "'Fira Code', 'JetBrains Mono', monospace"
  font.heading: "'Fira Code', 'JetBrains Mono', monospace"

  radius.sm: "6px"
  radius.md: "8px"
  radius.lg: "12px"

  borders.default: "1px solid #44475A"
  borders.strong: "1px solid #6272A4"

  elevation.flat: "none"
  elevation.raised: "0 2px 6px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2)"
  elevation.layered: "0 4px 10px rgba(0,0,0,0.3), 0 2px 4px rgba(0,0,0,0.2)"
  elevation.floating: "0 12px 30px rgba(0,0,0,0.4), 0 4px 10px rgba(0,0,0,0.2)"
  elevation.overlay: "0 8px 32px rgba(0,0,0,0.45)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  // Component tokens
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#343746"
  btn-secondary-color: "#F8F8F2"
  btn-secondary-border: "#6272A4"
  btn-secondary-hover: "#44475A"
  btn-ghost-color: "#BFBFBF"
  btn-ghost-hover: "#44475A"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#343746"
  input-border: "#6272A4"
  input-color: "#F8F8F2"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#44475A"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#21222C"
  select-border: "#6272A4"
  select-bg: "#343746"
  select-optionHover: "#44475A"
  select-optionSelected: "#2D2B3D"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#343746"
  modal-shadow: "0 20px 60px rgba(0,0,0,.45)"
  checkbox-border: "#6272A4"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#44475A"
  tab-hoverBg: "rgba(255,255,255,.05)"
  // Alert — Dracula severity
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Dracula palette
  gradient.stat-primary: "linear-gradient(135deg, #282A36, #2D2B3D)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #282A36, #2A2838)"
  gradient.stat-success: "linear-gradient(135deg, #1A3328, #234430)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #282A36, #1A3328)"
  gradient.stat-warning: "linear-gradient(135deg, #3D3020, #4A3A28)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #282A36, #3D3020)"
  gradient.stat-neutral: "linear-gradient(135deg, #282A36, #343746)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #282A36, #2E3040)"
  gradient.header-accent: "linear-gradient(135deg, rgba(189,147,249,0.15), rgba(189,147,249,0.05))"
  // Badge — Dracula
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#343746"
  badge-neutral-color: "#BFBFBF"
  badge-neutral-border: "#44475A"
  // Progress
  progress-trackBg: "#44475A"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#44475A"
  skeleton-shimmer: "rgba(255,255,255,0.06)"
  grid-borderColor: "#44475A"
  grid-headerBg: "#282A36"
  grid-filterBg: "#282A36"
  grid-filterBorder: "#6272A4"
  grid-rowBorder: "#343746"
  grid-selectedBg: "#2D2B3D"
  scrollbar-color: "#6272A4 #282A36"
}
