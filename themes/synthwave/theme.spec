@theme synthwave {
  palette.primary: pink
  semantic.surface: "#241B2F"
  semantic.surface-raised: "#2E2440"
  semantic.surface-hover: "#3B3050"
  semantic.background: "#1A1228"
  semantic.border: "#463868"
  semantic.border-strong: "#6048A0"
  semantic.text-primary: "#F0E8FF"
  semantic.text-secondary: "#D0C0F0"
  semantic.text-tertiary: "#9080B8"
  semantic.text-disabled: "#584880"
  semantic.text-muted: "#B0A0D0"
  semantic.text-strong: "#FFFFFF"
  semantic.interactive: "#FF7AC6"
  semantic.interactive-hover: "#FF4DB0"
  semantic.interactive-active: "#E03090"
  semantic.focus-ring: "rgba(255,122,198,0.4)"
  semantic.info-bg: "#282040"
  semantic.surface-unread: "#302548"
  semantic.destructive: "#FF3860"
  semantic.destructive-hover: "#E02050"
  semantic.error: "#FF3860"
  semantic.error-bg: "#351828"
  semantic.success: "#72F1B8"
  semantic.success-light: "#1A3028"
  semantic.success-muted: "#204030"
  semantic.success-text: "#72F1B8"
  semantic.success-mid: "#56D89E"
  semantic.warning: "#FEDE5D"
  semantic.warning-light: "#302E18"
  semantic.warning-muted: "#3E3C20"
  semantic.warning-text: "#FEDE5D"
  semantic.on-interactive: "#1A1228"
  semantic.on-destructive: "#1A1228"
  semantic.focus-ring-shadow: "rgba(255,122,198,.2)"
  // Severity
  severity.info-bg: "#282040"
  severity.info-color: "#36F9F6"
  severity.info-border: "#463868"
  severity.success-bg: "#1A3028"
  severity.success-color: "#72F1B8"
  severity.success-border: "#204030"
  severity.warning-bg: "#302E18"
  severity.warning-color: "#FEDE5D"
  severity.warning-border: "#3E3C20"
  severity.error-bg: "#351828"
  severity.error-color: "#FF3860"
  severity.error-border: "#482030"

  font.body: "'Inter', 'Segoe UI', sans-serif"
  font.heading: "'Inter', 'Segoe UI', sans-serif"

  radius.sm: "6px"
  radius.md: "8px"
  radius.lg: "12px"

  borders.default: "1px solid #463868"
  borders.strong: "1px solid #6048A0"

  elevation.flat: "none"
  elevation.raised: "0 2px 8px rgba(255,122,198,0.1), 0 1px 3px rgba(0,0,0,0.25)"
  elevation.layered: "0 4px 16px rgba(255,122,198,0.1), 0 2px 6px rgba(0,0,0,0.25)"
  elevation.floating: "0 8px 32px rgba(255,122,198,0.15), 0 4px 12px rgba(0,0,0,0.3)"
  elevation.overlay: "0 12px 48px rgba(255,122,198,0.15), 0 0 0 1px rgba(255,122,198,0.1)"
  elevation.inset: "inset 0 2px 4px rgba(0,0,0,0.3)"

  btn-radius: "8px"
  btn-primary-bg: "semantic.interactive"
  btn-primary-color: "semantic.on-interactive"
  btn-primary-hover: "semantic.interactive-hover"
  btn-secondary-bg: "#2E2440"
  btn-secondary-color: "#F0E8FF"
  btn-secondary-border: "#6048A0"
  btn-secondary-hover: "#3B3050"
  btn-ghost-color: "#D0C0F0"
  btn-ghost-hover: "#3B3050"
  btn-destructive-bg: "semantic.destructive"
  btn-destructive-color: "semantic.on-destructive"
  btn-destructive-hover: "semantic.destructive-hover"
  input-bg: "#2E2440"
  input-border: "#6048A0"
  input-color: "#F0E8FF"
  input-focusBorder: "semantic.interactive"
  input-focusRing: "semantic.focus-ring-shadow"
  toggle-trackBg: "#463868"
  toggle-trackBgOn: "semantic.interactive"
  toggle-thumbBg: "#1A1228"
  select-border: "#6048A0"
  select-bg: "#2E2440"
  select-optionHover: "#3B3050"
  select-optionSelected: "#302548"
  modal-backdropBg: "rgba(0,0,0,.6)"
  modal-bg: "#2E2440"
  modal-radius: "12px"
  modal-shadow: "0 20px 60px rgba(255,122,198,.15), 0 0 0 1px rgba(255,122,198,0.1)"
  checkbox-border: "#6048A0"
  checkbox-checkedBg: "semantic.interactive"
  tab-activeColor: "semantic.interactive"
  tab-borderColor: "#463868"
  tab-hoverBg: "rgba(255,255,255,.05)"
  // Alert — Synthwave
  alert-info-bg: "severity.info-bg"
  alert-info-border: "severity.info-color"
  alert-info-text: "severity.info-color"
  alert-success-bg: "severity.success-bg"
  alert-success-border: "severity.success-color"
  alert-success-text: "severity.success-color"
  alert-warning-bg: "severity.warning-bg"
  alert-warning-border: "severity.warning-color"
  alert-warning-text: "severity.warning-color"
  alert-error-bg: "severity.error-bg"
  alert-error-border: "severity.error-color"
  alert-error-text: "severity.error-color"
  // Stat card gradients — Synthwave
  gradient.stat-primary: "linear-gradient(135deg, #241B2F, #302548)"
  gradient.stat-primary-subtle: "linear-gradient(135deg, #241B2F, #282040)"
  gradient.stat-success: "linear-gradient(135deg, #1A3028, #204030)"
  gradient.stat-success-subtle: "linear-gradient(135deg, #241B2F, #1A3028)"
  gradient.stat-warning: "linear-gradient(135deg, #302E18, #3E3C20)"
  gradient.stat-warning-subtle: "linear-gradient(135deg, #241B2F, #302E18)"
  gradient.stat-neutral: "linear-gradient(135deg, #241B2F, #2E2440)"
  gradient.stat-neutral-subtle: "linear-gradient(135deg, #241B2F, #282038)"
  gradient.header-accent: "linear-gradient(135deg, rgba(255,122,198,0.15), rgba(54,249,246,0.08))"
  // Badge — Synthwave
  badge-borderWidth: "1px"
  badge-info-bg: "severity.info-bg"
  badge-info-color: "severity.info-color"
  badge-info-border: "severity.info-border"
  badge-success-bg: "severity.success-bg"
  badge-success-color: "severity.success-color"
  badge-success-border: "severity.success-border"
  badge-warning-bg: "severity.warning-bg"
  badge-warning-color: "severity.warning-color"
  badge-warning-border: "severity.warning-border"
  badge-error-bg: "severity.error-bg"
  badge-error-color: "severity.error-color"
  badge-error-border: "severity.error-border"
  badge-neutral-bg: "#2E2440"
  badge-neutral-color: "#D0C0F0"
  badge-neutral-border: "#463868"
  // Progress
  progress-trackBg: "#463868"
  progress-fillBg: "semantic.interactive"
  // Skeleton + Grid
  skeleton-bg: "#3B3050"
  skeleton-shimmer: "rgba(255,122,198,0.06)"
  grid-borderColor: "#463868"
  grid-headerBg: "#241B2F"
  grid-filterBg: "#241B2F"
  grid-filterBorder: "#6048A0"
  grid-rowBorder: "#2E2440"
  grid-selectedBg: "#302548"
  scrollbar-color: "#6048A0 #241B2F"
}
